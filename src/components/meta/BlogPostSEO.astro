---
import type { CollectionEntry } from "astro:content"
import { SEO } from "astro-seo"
import type { Article, WebPage, WithContext } from "schema-dts"

import JsonLD from "@/components/meta/JsonLD.astro"

type Props = {
  entry: CollectionEntry<"posts">
}

const {
  entry: { data, slug },
} = Astro.props

const postUrl = new URL(`/blog/post/${slug}`, Astro.url)

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  name: data.title,
  headline: data.title,
  description: data.description,
  image: data.thumbnail,
  datePublished: data.createdAt.toISOString(),
  dateModified: data.updatedAt?.toISOString(),
  url: postUrl.toString(),
} as const satisfies WithContext<Article | WebPage>
---

<SEO
  openGraph={{
    basic: {
      title: data.title,
      type: "article",
      image: data.thumbnail,
      url: postUrl.toString(),
    },
    image: {
      url: data.thumbnail,
      width: 1200,
      height: 630,
      alt: data.title,
    },
    article: {
      publishedTime: data.createdAt.toISOString(),
      modifiedTime: data.updatedAt?.toISOString(),
      tags: data.tags,
    },
    optional: {
      description: data.description,
      locale: "ja_JP",
    },
  }}
  twitter={{
    title: data.title,
    description: data.description,
    card: "summary_large_image",
    image: data.thumbnail,
  }}
  description={data.description}
  title={data.title}
  titleDefault="すしにっき"
  titleTemplate="%s - すしにっき"
/>

<JsonLD schema={schema} />
